{
  "$schema": "https://www.designtokens.org/schemas/2025.10/format.json",

  "fontFamily": {
    "$type": "fontFamily",
    "sans": {
      "$value": ["Inter", "system-ui", "sans-serif"],
      "$description": "Primary typeface. Use for all UI text, marketing copy, and documentation."
    },
    "mono": {
      "$value": ["JetBrains Mono", "Fira Code", "monospace"],
      "$description": "Monospace typeface. Use for code snippets, CLI commands, and technical references."
    }
  },

  "fontSize": {
    "$type": "dimension",
    "$description": "Type scale based on a 1.25 ratio.",
    "xs": { "$value": { "value": 12, "unit": "px" }, "$description": "Extra small. Captions, labels, and fine print." },
    "sm": {
      "$value": { "value": 14, "unit": "px" },
      "$description": "Small. Secondary text, metadata, and table content."
    },
    "base": { "$value": { "value": 16, "unit": "px" }, "$description": "Base size. Body text and UI labels." },
    "lg": { "$value": { "value": 18, "unit": "px" }, "$description": "Large. Subheadings and emphasized body text." },
    "xl": { "$value": { "value": 20, "unit": "px" }, "$description": "Extra large. Section headings." },
    "2xl": { "$value": { "value": 24, "unit": "px" }, "$description": "Page-level headings." },
    "3xl": { "$value": { "value": 30, "unit": "px" }, "$description": "Major headings." },
    "4xl": { "$value": { "value": 36, "unit": "px" }, "$description": "Hero headings (product)." },
    "5xl": { "$value": { "value": 48, "unit": "px" }, "$description": "Hero headings (marketing)." }
  },

  "fontWeight": {
    "$type": "fontWeight",
    "regular": { "$value": 400, "$description": "Body text and UI labels." },
    "medium": { "$value": 500, "$description": "Emphasized text, navigation items." },
    "semibold": { "$value": 600, "$description": "Subheadings and button labels." },
    "bold": { "$value": 700, "$description": "Headings and strong emphasis." }
  },

  "lineHeight": {
    "$type": "number",
    "tight": { "$value": 1.2, "$description": "Headings and display text." },
    "normal": { "$value": 1.5, "$description": "Body text." },
    "relaxed": { "$value": 1.75, "$description": "Long-form content and documentation." }
  }
}
