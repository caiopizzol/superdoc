{
  "$schema": "https://www.designtokens.org/schemas/2025.10/format.json",

  "spacing": {
    "$type": "dimension",
    "$description": "Spacing scale based on a 4px grid.",
    "0": { "$value": { "value": 0, "unit": "px" } },
    "1": { "$value": { "value": 4, "unit": "px" }, "$description": "Minimal spacing. Inline element gaps." },
    "2": {
      "$value": { "value": 8, "unit": "px" },
      "$description": "Tight spacing. Icon-to-label gaps, compact lists."
    },
    "3": { "$value": { "value": 12, "unit": "px" }, "$description": "Small spacing. Form field internal padding." },
    "4": { "$value": { "value": 16, "unit": "px" }, "$description": "Base spacing. Card padding, section gaps." },
    "5": { "$value": { "value": 20, "unit": "px" }, "$description": "Medium spacing." },
    "6": { "$value": { "value": 24, "unit": "px" }, "$description": "Comfortable spacing. Content block gaps." },
    "8": { "$value": { "value": 32, "unit": "px" }, "$description": "Large spacing. Section separators." },
    "10": { "$value": { "value": 40, "unit": "px" }, "$description": "Extra large spacing." },
    "12": { "$value": { "value": 48, "unit": "px" }, "$description": "Page-level spacing." },
    "16": { "$value": { "value": 64, "unit": "px" }, "$description": "Major section gaps." }
  },

  "borderRadius": {
    "$type": "dimension",
    "$description": "Border radius scale.",
    "none": { "$value": { "value": 0, "unit": "px" }, "$description": "No rounding. Document content areas." },
    "sm": { "$value": { "value": 4, "unit": "px" }, "$description": "Subtle rounding. Buttons, inputs, tags." },
    "md": { "$value": { "value": 8, "unit": "px" }, "$description": "Standard rounding. Cards, dropdowns." },
    "lg": { "$value": { "value": 12, "unit": "px" }, "$description": "Pronounced rounding. Modals, panels." },
    "xl": { "$value": { "value": 16, "unit": "px" }, "$description": "Large rounding. Marketing elements." },
    "full": { "$value": { "value": 9999, "unit": "px" }, "$description": "Pill shape. Badges, avatars." }
  }
}
