{
  "$schema": "https://www.designtokens.org/schemas/2025.10/format.json",
  "$description": "Semantic tokens for light theme. These map primitive values to UI roles.",

  "action": {
    "$type": "color",
    "$description": "Interactive element colors.",
    "primary": { "$value": "{blue.500}", "$description": "Primary buttons, main CTAs." },
    "primaryHover": { "$value": "{blue.600}", "$description": "Primary button hover." },
    "primaryActive": { "$value": "{blue.700}", "$description": "Primary button pressed/active." },
    "secondary": { "$value": "{white}", "$description": "Secondary button background." },
    "secondaryBorder": { "$value": "{gray.400}", "$description": "Secondary button border." },
    "secondaryHover": { "$value": "{gray.100}", "$description": "Secondary button hover background." },
    "destructive": { "$value": "{red.500}", "$description": "Destructive/delete buttons." },
    "destructiveHover": { "$value": "{red.600}", "$description": "Destructive button hover." },
    "disabled": { "$value": "{gray.400}", "$description": "Disabled button background." },
    "disabledText": { "$value": "{gray.500}", "$description": "Disabled button text." }
  },

  "text": {
    "$type": "color",
    "$description": "Text colors.",
    "primary": { "$value": "{gray.900}", "$description": "Headings and body text." },
    "secondary": { "$value": "{gray.700}", "$description": "Supporting text, descriptions." },
    "muted": { "$value": "{gray.600}", "$description": "Metadata, timestamps, captions." },
    "placeholder": { "$value": "{gray.500}", "$description": "Input placeholder text." },
    "disabled": { "$value": "{gray.500}", "$description": "Disabled element text." },
    "inverse": { "$value": "{white}", "$description": "Text on dark/primary backgrounds." },
    "link": { "$value": "{blue.500}", "$description": "Hyperlinks." },
    "linkHover": { "$value": "{blue.600}", "$description": "Hyperlink hover." },
    "error": { "$value": "{red.500}", "$description": "Error messages and validation." },
    "success": { "$value": "{green.500}", "$description": "Success messages." }
  },

  "surface": {
    "$type": "color",
    "$description": "Background and surface colors.",
    "page": { "$value": "{white}", "$description": "Document page background." },
    "canvas": { "$value": "{gray.50}", "$description": "Canvas behind document pages." },
    "card": { "$value": "{white}", "$description": "Card and panel backgrounds." },
    "elevated": { "$value": "{white}", "$description": "Elevated surfaces (modals, dropdowns)." },
    "hover": { "$value": "{gray.200}", "$description": "General hover background." },
    "selected": { "$value": "{blue.100}", "$description": "Selected item background." },
    "muted": { "$value": "{gray.100}", "$description": "Muted/secondary surface." }
  },

  "border": {
    "$type": "color",
    "$description": "Border colors.",
    "default": { "$value": "{gray.400}", "$description": "Standard borders (inputs, dividers)." },
    "subtle": { "$value": "{gray.300}", "$description": "Subtle borders (cards, sections)." },
    "focus": { "$value": "{blue.500}", "$description": "Focus ring color." },
    "error": { "$value": "{red.500}", "$description": "Error state border." }
  },

  "trackChanges": {
    "$type": "color",
    "$description": "Track changes / revision markup colors.",
    "insertionBorder": { "$value": "{green.500}", "$description": "Insertion border indicator." },
    "insertionBg": { "$value": "#399C7222", "$description": "Insertion background highlight (translucent green)." },
    "deletionBorder": { "$value": "{rose.500}", "$description": "Deletion border indicator." },
    "deletionBg": { "$value": "#CB0E4722", "$description": "Deletion background highlight (translucent rose)." }
  },

  "selection": {
    "$type": "color",
    "$description": "Editor selection and cursor colors.",
    "background": { "$value": "#629BE7", "$description": "Text selection highlight." },
    "handle": { "$value": "{blue.500}", "$description": "Resize handles and drag indicators." }
  }
}
