{
  "$schema": "https://www.designtokens.org/schemas/2025.10/format.json",
  "$description": "Semantic tokens for dark theme. Currently used on the homepage/marketing site.",

  "action": {
    "$type": "color",
    "primary": { "$value": "{blue.400}", "$description": "Primary buttons in dark mode." },
    "primaryHover": { "$value": "{blue.300}", "$description": "Primary button hover in dark mode." },
    "primaryActive": { "$value": "{blue.500}", "$description": "Primary button pressed in dark mode." }
  },

  "text": {
    "$type": "color",
    "primary": { "$value": "#E8E8E8", "$description": "Primary text on dark backgrounds." },
    "secondary": { "$value": "#A0A0A0", "$description": "Supporting text on dark backgrounds." },
    "muted": { "$value": "#666666", "$description": "De-emphasized text on dark backgrounds." },
    "link": { "$value": "{blue.300}", "$description": "Links on dark backgrounds." },
    "linkHover": { "$value": "{blue.200}", "$description": "Link hover on dark backgrounds." }
  },

  "surface": {
    "$type": "color",
    "page": { "$value": "{dark.900}", "$description": "Main dark background." },
    "card": { "$value": "{dark.800}", "$description": "Card/panel background in dark mode." },
    "elevated": { "$value": "{dark.700}", "$description": "Elevated surfaces in dark mode." }
  },

  "border": {
    "$type": "color",
    "default": { "$value": "#2A2D38", "$description": "Standard border in dark mode." },
    "subtle": { "$value": "#1E212B", "$description": "Subtle border in dark mode." },
    "focus": { "$value": "{blue.400}", "$description": "Focus ring in dark mode." }
  }
}
